set shell := ["powershell.exe", "-c"]

default:
  just --list

compile:
  go build

compileopt:
  cargo build --release

crun: compile run

run *ARGS:
  .\hello {{ARGS}}

test:
  cargo test

bench *ARGS:
  hyperfine ".\hello  {{ARGS}}"

benchopt *ARGS:
  hyperfine --warmup 3 ".\hello  {{ARGS}}"

benchmem *ARGS:
  ..\Measure-Exec.ps1 ".\hello" -Arguments "{{ARGS}}"

