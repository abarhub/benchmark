set shell := ["powershell.exe", "-c"]

default:
  just --list

compile:
  mvn clean package

crun: compile run

run *ARGS:
  java -cp target/classes com.exemple.HelloWorld {{ARGS}}

test:
  mvn test

bench *ARGS:
  hyperfine --warmup 3 "java -cp target/classes com.exemple.HelloWorld {{ARGS}}"

benchmem *ARGS:
  ..\Measure-Exec.ps1 "java" -Arguments "-cp target/classes com.exemple.HelloWorld {{ARGS}}"
